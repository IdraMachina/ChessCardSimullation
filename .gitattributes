# Normalize text files
* text=auto eol=lf

# C# and text-based source/config files
*.cs text diff=csharp
*.shader text
*.compute text
*.hlsl text
*.cginc text
*.json text
*.asmdef text
*.asmref text
*.meta text eol=lf

# Unity YAML-based assets
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.playable text eol=lf

# Binary assets handled by Git LFS
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.psb filter=lfs diff=lfs merge=lfs -text

*.fbx filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.blend1 filter=lfs diff=lfs merge=lfs -text

*.mp3 filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text

*.clip filter=lfs diff=lfs merge=lfs -text

# Font source files handled by Git LFS
Assets/Font/*.ttf filter=lfs diff=lfs merge=lfs -text
Assets/Font/*.otf filter=lfs diff=lfs merge=lfs -text

# Font asset files only
# Place this after the generic *.asset text rule so this path-specific LFS rule wins
Assets/Font/FontAsset/**/*.asset filter=lfs diff=lfs merge=lfs -text